# =========================================================================
# QuizSync Environment Configuration Template
# Copy this file to a local '.env' file before launching server runtimes.
# =========================================================================

# Application execution parameters
PORT=3000
NODE_ENV=production

# Security & CORS limits
# Comma-separated list of approved Origins allowed to access api endpoints
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:3000

# Express API request limits
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes (in milliseconds)
RATE_LIMIT_MAX_REQUESTS=100  # Max request cycles allowed per client IP
